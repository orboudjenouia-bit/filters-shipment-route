
generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

enum UserType {
  BUSINESS
  INDIVIDUAL
}

enum Roles {
  USER
  ADMIN
}

enum PostType {
  ORIGIN_DESTINATION
  REGION
}

enum DateType {
  DAY
  INTERVAL
}
enum Statustype {
  ACTIVE
  SUSPENDED
}
model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique @db.VarChar(50)
  password      String?
  phone         String   @db.VarChar(10)
  profile_Photo String?
  working_Time  String?
  type          UserType
  role          Roles
  status        Statustype
  createdAt     DateTime @default(now())

  resetPasswordToken String?
  resetPasswordExpires DateTime?
  verificationToken String? @db.VarChar(10)
  verificationTokenExpires DateTime?
  isVerified Boolean @default(false)

  individual    Individual?
  business      Business?
  subscription  Subscription?
  notifSettings NotificationSettings?

  vehicles       Vehicle[]
  shipments      Shipment[]
  routes         Route[]
  notifications  Notification[]
  
}

model Individual {
  user_ID   Int    @id
  user      User   @relation(fields: [user_ID], references: [id])

  full_Name String
  nin       String @unique
  location  String
}

model Business {
  user_ID       Int      @id
  user          User     @relation(fields: [user_ID], references: [id])

  business_Name String
  rc_Number     String   @unique
  form          String
  nif           Int
  nis           Int
  locations     String[]
}

model Vehicle {
  plate_Number  Int     @id
  vehicle_Name  String  
  type          String?
  color         String?
  year          Int?
  capacity      Int
  photo         String
  deleted_at    DateTime?
  
  user_ID       Int
  user          User    @relation(fields: [user_ID], references: [id])

  routes        Route[]
}

model Route {
  route_ID          Int     @id @unique @default(autoincrement())
  name              String?
  photo             String? @db.Text
  origin            String? 
  destination       String? 
  region            String?
  date              String? @db.VarChar(30)
  post_type         PostType @default(ORIGIN_DESTINATION)
  date_type         DateType @default(DAY)
  interval_start    String? @db.VarChar(10)
  interval_end      String? @db.VarChar(10)
  more_Information  String?  @db.Text
  status            String  @default("Active")
  createdAt         DateTime @default(now())

  
  user_ID           Int
  user              User    @relation(fields: [user_ID], references: [id])
  

  vehicle_plate     Int
  vehicle           Vehicle    @relation(fields: [vehicle_plate], references: [plate_Number])

}


model Shipment {
  shipment_ID         Int     @id @default(autoincrement())
  title               String?
  category            String?
  photo               String? @db.Text
  origin              String  
  destination         String  
  volume              Int
  weight              Int                    
  date                String  @db.VarChar(11) 
  time                String? @db.VarChar(5)
  priority            String  @default("Normal")
  special_Information String? @db.Text
  status              String  @default("In-Stock")
  createdAt           DateTime @default(now())

  user_ID             Int
  user                User    @relation(fields: [user_ID], references: [id])

}

model Subscription {
  sub_ID     Int       @id @default(autoincrement())
  tier       String     
  startDate  DateTime? @default(now())
  endDate    DateTime? @default(dbgenerated("(CURRENT_TIMESTAMP + interval '1 month')"))
  isActive   Boolean   @default(true)

  user_ID   Int        @unique
  user      User       @relation(fields: [user_ID], references: [id])

}

model Notification {
  notif_ID   Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  title      String
  message    String
  type       String 
  isRead     Boolean  @default(false)
  entityType String
  entityID   Int

  user_ID    Int
  user       User     @relation(fields: [user_ID], references: [id])
}

model NotificationSettings {
  id               Int     @id @default(autoincrement())
  emailEnabled     Boolean @default(true)
  pushEnabled      Boolean @default(true)
  shipmentUpdates  Boolean @default(true)
  routeUpdates     Boolean @default(true)
  Reminders        Boolean @default(true)

  user_ID          Int    @unique
  user             User   @relation(fields: [user_ID], references: [id])
}